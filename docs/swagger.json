{
  "openapi": "3.0.0",
  "info": {
    "title": "WhatsApp Multi-Account API",
    "version": "1.1.0",
    "description": "API documentation for the WhatsApp Baileys integration with Multi-Account support"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Initialize/Login an account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "string", "example": "my_account_1" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "QR generated" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "string", "example": "my_account_1" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Logged out" }
        }
      }
    },
    "/auth/{accountId}": {
      "delete": {
        "summary": "Delete account and all session data",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/auth/status": {
      "get": {
        "summary": "Get connection status",
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Current status" }
        }
      }
    },
    "/auth/accounts": {
      "get": {
        "summary": "List all accounts",
        "responses": {
          "200": { "description": "List of accounts" }
        }
      }
    },
    "/messages/send": {
      "post": {
        "summary": "Send direct message",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "string", "example": "my_account_1" },
                  "to": { "type": "string", "example": "849xxxxxxxx@s.whatsapp.net" },
                  "message": { "type": "string", "example": "Hello" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Message sent" }
        }
      }
    },
    "/groups/list": {
      "get": {
        "summary": "List all participating groups",
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "List of groups" }
        }
      }
    },
    "/groups/send": {
      "post": {
        "summary": "Send message to a group",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "string", "example": "my_account_1" },
                  "groupId": { "type": "string", "example": "123456789@g.us" },
                  "message": { "type": "string", "example": "Hello group" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Group message sent" }
        }
      }
    },
    "/settings/webhook": {
      "get": {
        "summary": "Get webhook configuration",
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Webhook URL" }
        }
      },
      "post": {
        "summary": "Update webhook configuration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "string", "example": "my_account_1" },
                  "webhookUrl": { "type": "string", "example": "https://myserver.com/callback" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Webhook updated" }
        }
      }
    }
  }
}
